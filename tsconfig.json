{
  "compilerOptions": {
    "declaration": true,
    "target": "es2024",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "outDir": "./dist",
    "rootDir": "./",
    "paths": {
      "@hsm-chatbot-lib/common": [
        "./libs/common/src"
      ],
      "@hsm-chatbot-lib/common/*": [
        "./libs/common/src/*"
      ],
      "@hsm-chatbot-lib/definitions": [
        "./libs/definitions/src"
      ],
      "@hsm-chatbot-lib/definitions/*": [
        "./libs/definitions/src/*"
      ],
    },
    "sourceMap": true,
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "noImplicitAny": false,
  },
  "watchOptions": {
    "watchFile": "dynamicPriorityPolling",
    "watchDirectory": "dynamicPriorityPolling",
    "excludeDirectories": [
      "**/node_modules",
      "dist"
    ]
  }
}